-- 6. INTEROGARI SI SUBINTEROGARI


-- Afisare carti cu autor si editura
SELECT C.titlu, A.nume + ' ' + A.prenume AS Autor,
       E.denumire AS Editura, C.pret
FROM Carte C
JOIN Autor A ON C.id_autor = A.id_autor
JOIN Editura E ON C.id_editura = E.id_editura;

-- Carti cu pret peste media
SELECT titlu, pret
FROM Carte
WHERE pret > (SELECT AVG(pret) FROM Carte);

-- Total valoare carti
SELECT SUM(pret) AS TotalValoareCarti
FROM Carte;

-- Subtotal pe gen
SELECT gen, SUM(pret) AS TotalPeGen
FROM Carte
GROUP BY gen;

-- Total imprumuturi per cititor
SELECT C.nume_cititor, COUNT(I.id_imprumut) AS TotalImprumuturi
FROM Cititor C
LEFT JOIN Imprumut I ON C.id_cititor = I.id_cititor
GROUP BY C.nume_cititor;

-- Viziuni
CREATE VIEW vw_CartiDetalii
AS
SELECT 
    C.id_carte,
    C.titlu,
    C.gen,
    C.an_publicare,
    C.pret,
    A.nume + ' ' + A.prenume AS Autor,
    E.denumire AS Editura
FROM Carte C
JOIN Autor A ON C.id_autor = A.id_autor
JOIN Editura E ON C.id_editura = E.id_editura;
GO
SELECT * FROM vw_CartiDetalii;
---------------------------------


CREATE VIEW vw_ImprumuturiActive
AS
SELECT 
    I.id_imprumut,
    C.titlu,
    Ct.nume_cititor + ' ' + Ct.prenume AS Cititor,
    I.data_imprumut
FROM Imprumut I
JOIN Carte C ON I.id_carte = C.id_carte
JOIN Cititor Ct ON I.id_cititor = Ct.id_cititor
WHERE I.data_returnare IS NULL;
GO
SELECT * FROM vw_ImprumuturiActive;
------------------------
CREATE VIEW vw_TotalImprumuturiCititor
AS
SELECT 
    Ct.id_cititor,
    Ct.nume_cititor,
    Ct.prenume,
    COUNT(I.id_imprumut) AS TotalImprumuturi
FROM Cititor Ct
LEFT JOIN Imprumut I ON Ct.id_cititor = I.id_cititor
GROUP BY Ct.id_cititor, Ct.nume_cititor, Ct.prenume;
GO

CREATE VIEW vw_TotalValoarePeGen
AS
SELECT 
    gen,
    SUM(pret) AS TotalValoare
FROM Carte
GROUP BY gen;
GO

SELECT * FROM vw_TotalValoarePeGen;
