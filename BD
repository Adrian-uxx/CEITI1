
CREATE DATABASE BibliotecaDB;
GO

USE BibliotecaDB;
GO




-- Tabela Autor
CREATE TABLE Autor (
    id_autor INT PRIMARY KEY,  -- cheia primara generata prin functie
    nume NVARCHAR(50) NOT NULL,
    prenume NVARCHAR(50) NOT NULL,
    tara NVARCHAR(50),
    data_nasterii DATE
);
GO


-- Tabela Editura
CREATE TABLE Editura (
    id_editura INT PRIMARY KEY,
    denumire NVARCHAR(100) NOT NULL,
    tara NVARCHAR(50),
    adresa NVARCHAR(200),
    telefon NVARCHAR(15)
);
GO


-- Tabela Cititor
CREATE TABLE Cititor (
    id_cititor INT PRIMARY KEY,
    nume_cititor NVARCHAR(50) NOT NULL,
    prenume NVARCHAR(50) NOT NULL,
    adresa NVARCHAR(200),
    telefon NVARCHAR(15),
    email NVARCHAR(100) UNIQUE
);
GO


-- Tabela Carte
CREATE TABLE Carte (
    id_carte INT PRIMARY KEY,
    titlu NVARCHAR(100) NOT NULL,
    gen NVARCHAR(30),
    an_publicare INT,
    pret DECIMAL(10,2),
    id_autor INT,
    id_editura INT,

    FOREIGN KEY (id_autor) REFERENCES Autor(id_autor),
    FOREIGN KEY (id_editura) REFERENCES Editura(id_editura)
);
GO


-- Tabela Imprumut
CREATE TABLE Imprumut (
    id_imprumut INT PRIMARY KEY,
    id_carte INT,
    id_cititor INT,
    data_imprumut DATE NOT NULL,
    data_returnare DATE,

    FOREIGN KEY (id_carte) REFERENCES Carte(id_carte),
    FOREIGN KEY (id_cititor) REFERENCES Cititor(id_cititor)
);
GO



-- 3. FUNCTII UTILIZATOR PENTRU GENERARE CHEI PRIMARE

-- Functie generare ID Autor
CREATE FUNCTION fn_GenerareIdAutor()
RETURNS INT
AS
BEGIN
    RETURN (SELECT ISNULL(MAX(id_autor),0) + 1 FROM Autor);
END;
GO

-- Functie generare ID Editura
CREATE FUNCTION fn_GenerareIdEditura()
RETURNS INT
AS
BEGIN
    RETURN (SELECT ISNULL(MAX(id_editura),0) + 1 FROM Editura);
END;
GO

-- Functie generare ID Cititor
CREATE FUNCTION fn_GenerareIdCititor()
RETURNS INT
AS
BEGIN
    RETURN (SELECT ISNULL(MAX(id_cititor),0) + 1 FROM Cititor);
END;
GO

-- Functie generare ID Carte
CREATE FUNCTION fn_GenerareIdCarte()
RETURNS INT
AS
BEGIN
    RETURN (SELECT ISNULL(MAX(id_carte),0) + 1 FROM Carte);
END;
GO

-- Functie generare ID Imprumut
CREATE FUNCTION fn_GenerareIdImprumut()
RETURNS INT
AS
BEGIN
    RETURN (SELECT ISNULL(MAX(id_imprumut),0) + 1 FROM Imprumut);
END;
GO


-- 4. PROCEDURI STOCATE PENTRU INTRODUCERE DATE


-- Procedura Autor
CREATE PROCEDURE sp_AdaugaAutor
    @nume NVARCHAR(50),
    @prenume NVARCHAR(50),
    @tara NVARCHAR(50),
    @data_nasterii DATE
AS
BEGIN
    INSERT INTO Autor
    VALUES (dbo.fn_GenerareIdAutor(), @nume, @prenume, @tara, @data_nasterii);
END;
GO


-- Procedura Editura
CREATE PROCEDURE sp_AdaugaEditura
    @denumire NVARCHAR(100),
    @tara NVARCHAR(50),
    @adresa NVARCHAR(200),
    @telefon NVARCHAR(15)
AS
BEGIN
    INSERT INTO Editura
    VALUES (dbo.fn_GenerareIdEditura(), @denumire, @tara, @adresa, @telefon);
END;
GO


-- Procedura Cititor
CREATE PROCEDURE sp_AdaugaCititor
    @nume NVARCHAR(50),
    @prenume NVARCHAR(50),
    @adresa NVARCHAR(200),
    @telefon NVARCHAR(15),
    @email NVARCHAR(100)
AS
BEGIN
    INSERT INTO Cititor
    VALUES (dbo.fn_GenerareIdCititor(), @nume, @prenume, @adresa, @telefon, @email);
END;
GO


-- Procedura Carte
CREATE PROCEDURE sp_AdaugaCarte
    @titlu NVARCHAR(100),
    @gen NVARCHAR(30),
    @an_publicare INT,
    @pret DECIMAL(10,2),
    @id_autor INT,
    @id_editura INT
AS
BEGIN
    INSERT INTO Carte
    VALUES (dbo.fn_GenerareIdCarte(), @titlu, @gen, @an_publicare, @pret, @id_autor, @id_editura);
END;
GO


-- Procedura Imprumut
CREATE PROCEDURE sp_AdaugaImprumut
    @id_carte INT,
    @id_cititor INT,
    @data_imprumut DATE,
    @data_returnare DATE
AS
BEGIN
    INSERT INTO Imprumut
    VALUES (dbo.fn_GenerareIdImprumut(), @id_carte, @id_cititor, @data_imprumut, @data_returnare);
END;
GO


